<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#7B282A">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hourly"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#E7C51D"
            android:layout_marginBottom="16dp" />

        <!-- Pricing Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 - 6 hours"
                android:textSize="14sp"
                android:textColor="#E6E6E6"
                android:layout_marginBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E2E6"
                android:layout_marginVertical="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short Period: 1 - 2 hours"
                android:textSize="14sp"
                android:textColor="#E6E6E6"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium Period: 3 - 4 hours"
                android:textSize="14sp"
                android:textColor="#E6E6E6"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Long Period: 5 - 6 hours"
                android:textSize="14sp"
                android:textColor="#E6E6E6"
                android:layout_marginBottom="20dp" />
        </LinearLayout>

        <!-- Book Now Button -->
        <Button
            android:id="@+id/btnBookNow"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Book Now"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#7B282A"
            android:background="@drawable/rounded_button_accent"
            android:stateListAnimator="@null" />
    </LinearLayout>
</androidx.cardview.widget.CardView>