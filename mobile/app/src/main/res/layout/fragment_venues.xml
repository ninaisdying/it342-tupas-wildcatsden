<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Search and Filter Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <!-- Search Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find a Venue"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#7B282A"
            android:layout_marginBottom="8dp" />

        <!-- Search View -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="30dp"
            app:cardElevation="2dp">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:queryHint="Search venues..."
                app:iconifiedByDefault="false"
                app:queryBackground="@android:color/transparent" />
        </androidx.cardview.widget.CardView>

        <!-- Category Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categories"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#7B282A"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- Category Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/categoryChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:checked="true"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    android:textColor="@color/chip_text_selector" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipNGE"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NGE"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    android:textColor="@color/chip_text_selector" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSAL"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAL"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    android:textColor="@color/chip_text_selector" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGLE"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GLE"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    android:textColor="@color/chip_text_selector" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCourt"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Court"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    android:textColor="@color/chip_text_selector" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipACAD"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACAD"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    android:textColor="@color/chip_text_selector" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMore"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="More"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    android:textColor="@color/chip_text_selector" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Results Info -->
    <TextView
        android:id="@+id/resultsInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dp"
        android:textSize="13sp"
        android:textColor="#666666"
        android:background="#F0F0F0"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- Loading Spinner -->
    <ProgressBar
        android:id="@+id/loadingSpinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="60dp"
        android:visibility="gone" />

    <!-- Venues Grid (RecyclerView) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerVenues"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- No Results Message -->
    <LinearLayout
        android:id="@+id/noResultsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_no_results"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvNoResults"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No venues found"
            android:textColor="#7B282A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try adjusting your search or filters"
            android:textColor="#999999"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</LinearLayout>